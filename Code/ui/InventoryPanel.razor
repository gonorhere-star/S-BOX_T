@using Sandbox;
@using Sandbox.UI;
@using System.Collections.Generic;
@using System.Linq;
@inherits PanelComponent
@namespace Sandbox

<root>
    <div class="inventory-container">
        <div class="inventory-content">
            <div class="inventory-grid-wrapper">
                <div class="inventory-header">Инвентарь (@Items.Count/@MaxSlots) — [Цифры выбор] [E надеть/исп] [G выброс] [Alt+1-3 снять]</div>
                <div class="inventory-grid">
                    @for (int i = 0; i < Items.Count; i++)
                    {
                        var slot = Items[i];
                        <div class="inventory-slot" data-slot="@i">
                            <span class="item-icon">@slot.Definition.Icon</span>
                            <span class="item-name">@slot.Definition.Name</span>
                            @if (slot.Quantity > 1) { <span class="item-qty">@slot.Quantity</span> }
                        </div>
                    }
                    @for (int i = Items.Count; i < MaxSlots; i++)
                    {
                        <div class="inventory-slot empty" data-slot="@i"></div>
                    }
                </div>
            </div>

            <div class="equipment-panel">
                <div class="equipment-header">Экипировка [Alt+1/2/3 снять]</div>
                <div class="equipment-slots">
                    @foreach (var kv in EquipmentSlots)
                    {
                        <div class="equipment-slot" data-slot-name="@kv.Key">
                            <span class="slot-label">@GetSlotLabel(kv.Key)</span>
                            @if (kv.Value != null)
                            {
                                <span class="item-icon">@kv.Value.Definition.Icon</span>
                                <span class="item-name">@kv.Value.Definition.Name</span>
                            }
                            else
                            {
                                <span class="empty-icon">⭕</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</root>

@code {
    public bool IsVisible
    {
        get => Panel.Style.Display == DisplayMode.Flex;
        set => Panel.Style.Display = value ? DisplayMode.Flex : DisplayMode.None;
    }

    private List<InventorySlot> Items = new();
    private int MaxSlots = 16;
    private InventoryComponent inventoryComponent;
    private EquipmentComponent equipmentComponent;
    private Dictionary<string, InventorySlot> EquipmentSlots = new()
    {
        ["Helmet"] = null, ["Armor"] = null, ["Weapon"] = null
    };
    private InventorySlot selectedSlot;
    private Panel highlightedPanel;

    public void Initialize(GameObject playerObject)
    {
        inventoryComponent = playerObject.Components.Get<InventoryComponent>();
        equipmentComponent = playerObject.Components.Get<EquipmentComponent>();

        if (inventoryComponent != null)
        {
            inventoryComponent.OnInventoryChanged += UpdateFromInventory;
            UpdateFromInventory();
        }
        if (equipmentComponent != null)
        {
            equipmentComponent.OnEquipmentChanged += UpdateEquipment;
            UpdateEquipment();
        }
    }

    protected override void OnStart()
    {
        Panel.Style.Display = DisplayMode.None;
    }

    public void ToggleVisibility()
    {
        IsVisible = !IsVisible;
    }

    void UpdateFromInventory()
    {
        if (inventoryComponent == null) return;
        Items = new List<InventorySlot>(inventoryComponent.Items);
        MaxSlots = inventoryComponent.MaxSlots;
        if (selectedSlot != null && !Items.Contains(selectedSlot))
        {
            ClearHighlight();
        }
        StateHasChanged();
    }

    void UpdateEquipment()
    {
        if (equipmentComponent == null) return;
        EquipmentSlots = equipmentComponent.Slots.ToDictionary(k => k.Key, k => k.Value);
        StateHasChanged();
    }

    private void ClearHighlight()
    {
        if (highlightedPanel != null)
        {
            highlightedPanel.Style.BorderColor = Color.Transparent;
            highlightedPanel.Style.BorderWidth = 1;
            highlightedPanel = null;
        }
        selectedSlot = null;
    }

    private Panel GetGridPanel()
    {
        var container = Panel.GetChild(0) as Panel;
        if (container == null) return null;
        var content = container.GetChild(0) as Panel;
        if (content == null) return null;
        var gridWrapper = content.GetChild(0) as Panel;
        if (gridWrapper == null) return null;
        return gridWrapper.GetChild(1) as Panel;
    }

    public void SelectSlotByIndex(int index)
    {
        ClearHighlight();
        if (index < 0 || index >= Items.Count) return;

        var grid = GetGridPanel();
        if (grid == null) return;

        var slotPanel = grid.Children.ElementAtOrDefault(index);
        if (slotPanel == null) return;

        slotPanel.Style.BorderColor = Color.Parse("#ffaa00").GetValueOrDefault();
        slotPanel.Style.BorderWidth = 2;
        highlightedPanel = slotPanel;
        selectedSlot = Items[index];
    }

    public void DoPrimaryAction()
    {
        if (selectedSlot == null) return;
        var tags = selectedSlot.Definition.Tags ?? new List<string>();

        if (tags.Contains("weapon") || tags.Contains("armor") || tags.Contains("helmet"))
        {
            string target = null;
            if (tags.Contains("weapon")) target = "Weapon";
            else if (tags.Contains("armor")) target = "Armor";
            else if (tags.Contains("helmet")) target = "Helmet";

            if (target != null && equipmentComponent != null)
            {
                bool result = equipmentComponent.Equip(selectedSlot, target);
                if (result)
                {
                    if (equipmentComponent.Slots[target] == selectedSlot)
                        ClearHighlight();
                    StateHasChanged();
                }
            }
        }
        else if (tags.Contains("зелье") || tags.Contains("свиток") || tags.Contains("еда"))
        {
            inventoryComponent.RemoveItem(selectedSlot.Definition, 1);
            if (selectedSlot.Quantity <= 0) ClearHighlight();
            StateHasChanged();
        }
    }

    public void DoDropAction()
    {
        if (selectedSlot != null)
        {
            inventoryComponent?.DropItem(selectedSlot);
            ClearHighlight();
            StateHasChanged();
        }
    }

    public void UnequipSlot(string slotName)
    {
        Log.Info($"[InventoryPanel] UnequipSlot вызван для {slotName}, equipmentComponent is null: {equipmentComponent == null}");
        equipmentComponent?.Unequip(slotName);
        if (selectedSlot != null && EquipmentSlots.TryGetValue(slotName, out var slot) && slot == selectedSlot)
        {
            ClearHighlight();
        }
        StateHasChanged();
    }

    string GetSlotLabel(string s) => s switch
    {
        "Helmet" => "Шлем", "Armor" => "Броня", "Weapon" => "Оружие", _ => s
    };

    protected override int BuildHash() => System.HashCode.Combine(IsVisible, Items.Count);
}
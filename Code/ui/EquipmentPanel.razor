@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Sandbox

<root>
    <div class="equipment-panel @(IsVisible ? "visible" : "hidden")">
        <div class="equipment-header">Экипировка</div>
        @foreach (var kv in Slots)
        {
            <div class="equipment-slot" data-slot-name="@kv.Key"
                 ondragover="return false" ondragenter="return false">
                <span class="slot-label">@kv.Key</span>
                @if (kv.Value != null)
                {
                    <span class="item-icon">@kv.Value.Definition.Icon</span>
                    <span class="item-name">@kv.Value.Definition.Name</span>
                }
                else
                {
                    <span class="empty-icon">⭕</span>
                }
            </div>
        }
    </div>
</root>

@code {
    [Property] public bool IsVisible { get; set; } = false;

    private EquipmentComponent equipmentComponent;
    private Dictionary<string, InventorySlot> Slots = new();

    protected override void OnStart()
    {
        var player = Scene.Directory.FindByName("Player")?.FirstOrDefault();
        if (player != null)
        {
            equipmentComponent = player.Components.Get<EquipmentComponent>();
            if (equipmentComponent != null)
            {
                equipmentComponent.OnEquipmentChanged += UpdateFromEquipment;
                UpdateFromEquipment();
            }
        }
    }

    void UpdateFromEquipment()
    {
        if (equipmentComponent == null) return;
        Slots = new Dictionary<string, InventorySlot>(equipmentComponent.Slots);
        StateHasChanged();
    }

    protected override int BuildHash() => System.HashCode.Combine(IsVisible, Slots.Count);
}